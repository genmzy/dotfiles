font-family = "Maple Mono"
font-family = "LXGW WenKai Mono"
font-variation = "wght=330"
font-variation-italic = "wght=330"
font-variation-bold = "wght=600"
font-variation-bold-italic = "wght=600"
font-size = 14.4
# serif f:cv11   a    g    r  ==>  f(i) l(i)
font-feature = "cv02,cv05,cv08,calt,cv32,cv35"
adjust-cell-height = 2
font-thicken = true
adjust-cell-width = 0
